# Sample nginx config for routing mcp.yourdomain.com → the local MCP container.
#
# Prerequisites:
#   - Obtain a TLS cert for mcp.yourdomain.com (e.g. via certbot / Let's Encrypt)
#   - Replace "mcp.yourdomain.com" with your actual subdomain
#   - Replace 4100 with your MCP_PORT if you changed it
#
# Place this file in /etc/nginx/sites-available/mcp and symlink to sites-enabled.

server {
    listen 80;
    server_name mcp.yourdomain.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name mcp.yourdomain.com;

    ssl_certificate     /etc/letsencrypt/live/mcp.yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mcp.yourdomain.com/privkey.pem;

    location / {
        proxy_pass         http://127.0.0.1:4100;
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Required for SSE (MCP streaming responses) and long-lived connections
        proxy_buffering    off;
        proxy_read_timeout 3600s;

        # Pass upgrade headers for potential WebSocket use
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection $connection_upgrade;
    }
}

# Required for the Connection upgrade header map (add once to nginx.conf http block if not present)
# map $http_upgrade $connection_upgrade {
#     default upgrade;
#     ''      close;
# }
