# ── D2L Brightspace ───────────────────────────────────────────────────────────
D2L_HOST=learn.yourschool.edu
D2L_USERNAME=your_username
D2L_PASSWORD=your_password

# ── Piazza (optional) ─────────────────────────────────────────────────────────
PIAZZA_USERNAME=your_piazza_email@school.edu
PIAZZA_PASSWORD=your_piazza_password

# ── OpenAI (required for semantic search / notes embeddings) ──────────────────
OPENAI_API_KEY=sk-...

# ── MCP Bearer Token ──────────────────────────────────────────────────────────
# This is the token your MCP client sends to authenticate.
# Generate one: openssl rand -hex 32
MCP_TOKEN=change_me_to_a_random_secret

# ── Database ──────────────────────────────────────────────────────────────────
# Internal postgres password — never exposed externally.
# Generate one: openssl rand -hex 16
DB_PASSWORD=change_me_to_a_random_password

# ── Optional ──────────────────────────────────────────────────────────────────
# Port the MCP server listens on (default: 4100).
# MCP_PORT=4100

# Your public hostname if using a reverse proxy (e.g. mcp.yourdomain.com).
# Only affects the Duo re-auth URL shown in tool responses. Defaults to localhost:4100.
# API_HOST=mcp.yourdomain.com
